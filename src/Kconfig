config PEROVSAT_AMU
	bool "AMU driver"
	depends on DT_HAS_AEROSPACE_AMU_ENABLED
	# Add bus dependency here:
	# select I2C
	help
	  Enable the AMU Zephyr driver module.

if PEROVSAT_AMU

choice
	prompt "AMU backend"
	default PEROVSAT_AMU_BACKEND_PUBLIC_MOCK

config PEROVSAT_AMU_BACKEND_HARDWARE
	bool "Hardware (real device over bus)"
	help
	  Use the device library with a real bus transfer function.

config PEROVSAT_AMU_BACKEND_SIMULATION
	bool "Simulation (socket to Basilisk)"
	help
	  Use the device library with a socket transfer function for SITL.

config PEROVSAT_AMU_BACKEND_LIBRARY_MOCK
	bool "Library mock (static register data via device library)"
	help
	  Use the device library with a static register-map transfer function.

config PEROVSAT_AMU_BACKEND_PUBLIC_MOCK
	bool "Public mock (hardcoded data, no library required)"
	help
	  Return hardcoded data from the Zephyr driver API without linking the
	  device library. Safe for CI and repos without NDA library access.

endchoice

endif
